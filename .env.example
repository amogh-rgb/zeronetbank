# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
ADMIN_API_TOKEN=change-this-admin-token

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zeronettbank
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key
REFRESH_TOKEN_EXPIRY=30d

# Bank Crypto
# These should come from HSM/secure vault in production
BANK_PRIVATE_KEY_HSM=false
BANK_PRIVATE_KEY_PATH=./secrets/bank-private-key.pem
BANK_PUBLIC_KEY_PATH=./secrets/bank-public-key.pem

# Email (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@zeronettbank.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
OTP_EXPIRY_SECONDS=300
DEVICE_FINGERPRINT_SALT=your-device-fingerprint-salt

# Monitoring
SENTRY_DSN=
AMPLITUDE_KEY=

# Features
ENABLE_FRAUD_DETECTION=true
ENABLE_WEBSOCKET=true
ENABLE_AUDIT_LOGGING=true

# Wallet Sync
WALLET_SYNC_TIMEOUT_SECONDS=30
MAX_CREDITS_PER_SYNC=100

# ===== BANK PAYMENT API INTEGRATION =====
# External Bank API Configuration
# ⚠ CRITICAL: NEVER commit actual API keys to git
# ⚠ CRITICAL: NEVER expose these to frontend

# Bank API Credentials (Replace with actual values)
BANK_API_KEY=your-bank-api-key-here
BANK_API_SECRET=your-bank-api-secret-here

# Bank API Endpoint
BANK_API_URL=https://api.bank-provider.com/v1

# Bank API Timeout (milliseconds)
BANK_API_TIMEOUT=30000

# Backend URL (for callbacks)
BACKEND_URL=http://localhost:3000
